# ---------------------------------------------------------------------------
# Environment configuration for the Intelligent Loan Eligibility Assistant
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- LLM provider (Claude / Anthropic-compatible) ---
# API key for your vendor-provided Claude-compatible endpoint.
ANTHROPIC_API_KEY=sk-lMg1RBu2Q09iXsw8QEkjnQ

# Vendor gateway base URL (Anthropic-compatible proxy).
ANTHROPIC_BASE_URL=https://llmgwext-wp.tekstac.com

# Claude model identifier enabled on the gateway.
# Options:
#   global.anthropic.claude-haiku-4-5-20251001-v1:0   (fast, lower cost)
#   global.anthropic.claude-sonnet-4-6                 (balanced)
#   global.anthropic.claude-opus-4-5-20251101-v1:0     (most capable)
ANTHROPIC_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Embeddings (local HuggingFace sentence-transformers, no API key) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store (FAISS) ---
# Directory where the FAISS index will be persisted.
VECTOR_STORE_DIR=vectorstore

# --- Data ---
# Path to the policy document used for the RAG feature.
POLICY_DOC_PATH=data/loan_policy.md
